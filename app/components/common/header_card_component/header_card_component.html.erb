<div class="aic-title-with-buttons page-header">
  <div class="content">
    <h5 class="card-title"><%= @title %></h2>
    <% if @subtitle %>
      <h6 class="card-subtitle mb-2 text-body-secondary"><%= @subtitle %></h6>
    <% end %>
  </div>
  <div class="buttons">
    <%= menu_items %>
    <%= buttons %>
  </div>
</div>
