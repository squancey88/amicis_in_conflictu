<%= form_with(model: army) do |form| %>

  <%= render RecordFormWrapperComponent.new(record: army, form:) do |component| %>

    <% component.with_form_box do %>

      <%= form.text_field :name, placeholder: "Name" %>
      <%= game_systems_with_army_select(form, :game_system_id) %>

    <% end %>
  <% end %>
<% end %>
