<%= form_with(model: world) do |form| %>

  <%= render RecordFormWrapperComponent.new(record: world, form:) do |component| %>

    <% component.with_form_box do %>
      <%= form.text_field(:name) %>
      <%= render TextEditorComponent.new(form:, attribute: :blurb) %>
    <% end %>

    <% component.with_form_box(title: "Character Settings") do %>
      <%= render JsonEditorComponent.new(model: world,
                                    attribute: :character_config,
                                    schema: Character.character_config_schema) %>
    <% end %>

    <% component.with_form_box(title: "Time Config") do %>
      <%= render JsonEditorComponent.new(model: world,
                                    attribute: :time_period_config,
                                    schema: World.time_period_schema) %>
    <% end %>

  <% end %>
<% end %>
