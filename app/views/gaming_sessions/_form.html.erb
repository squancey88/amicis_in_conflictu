<%= form_with(model: gaming_session, url: [@gaming_group, gaming_session]) do |form| %>

  <%= render RecordFormWrapperComponent.new(record: gaming_session, form:) do |component| %>

    <% component.with_form_box do %>

      <%= form.datetime_field :start_time, placeholder: "Start Time" %>

      <%= select_for_groups form, :gaming_group_id %>
    <% end %>

    <% component.with_form_box do %>
      <%= render TextEditorComponent.new(form: form, attribute: :notes) %>
    <% end %>
  <% end %>
<% end %>
