<%= form_with(model: unit_xp_gain_event) do |form| %>

  <%= render RecordFormWrapperComponent.new(record: unit_xp_gain_event, form:) do |component| %>

    <% component.with_form_box(title: "Details") do %>

      <%= form.text_field(:name) %>
      <%= form.number_field(:xp_gain) %>
      <%= form.check_box(:active) %>
      <%= form.hidden_field :game_system_id %>
            
    <% end %>
    <% component.with_form_box(title: "Description") do %>

      <%= render TextEditorComponent.new(form:, attribute: :description) %>
    <% end %>
  <% end %>
<% end %>
