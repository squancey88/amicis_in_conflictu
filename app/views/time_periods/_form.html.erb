<%= form_with(model: [@world, time_period]) do |form| %>

  <%= render RecordFormWrapperComponent.new(record: time_period, form:) do |component| %>

    <% component.with_form_box do %>
      <%= form.hidden_field(:world_id) %>

      <%= form.text_field(:name) %>
      <%= form.number_field(:order) %>
    <% end %>
    <% component.with_form_box do %>
      <%= render TextEditorComponent.new(form:, attribute: :description) %>
    <% end %>
  <% end %>
<% end %>
