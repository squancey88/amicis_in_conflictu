<%= form_with(model: equipment) do |form| %>

  <%= render RecordFormWrapperComponent.new(record: equipment, form:) do |component| %>

    <% component.with_form_box do %>

      <%= form.hidden_field :game_system_id %>
      <%= form.text_field(:name) %>
      <%= form.text_field(:description) %>
      <%= form.number_field(:cost) %>

      <%= form.check_box(:attach_to_list) %>
      <%= form.check_box(:attach_to_unit) %>
    <% end %>
  <% end %>
<% end %>
